{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1, "newProjectRoot": "projects",
  "projects": {
    "plugin": {
      "root": "projects/plugin", "sourceRoot": "projects/plugin/src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "outputPath": "dist", "index": false,
            "main": "projects/plugin/src/main.ts",
            "tsConfig": "projects/plugin/tsconfig.app.json",
            "assets": [
              { "glob": "**/*",         "input": "projects/plugin/src/i18n", "output": "/i18n" },
              { "glob": "manifest.json","input": "projects/plugin/src",      "output": "/" }
            ],
            "styles": [], "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true, "outputHashing": "none",
              "sourceMap": false, "namedChunks": false,
              "extractLicenses": true, "vendorChunk": false,
              "buildOptimizer": true
            }
          }
        }
      }
    }
  }
}